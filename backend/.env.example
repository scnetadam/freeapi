# 龟钮印证 L0 结算壳 — 环境变量

# ========== 服务配置 ==========
PORT=3000
NODE_ENV=development

# ========== 支付宝沙箱 (L1 通道) ==========
# 未配置时自动使用模拟模式
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# ========== 支付通道开关 ==========
# 逗号分隔: alipay,wechat,other
PAYMENT_CHANNELS=alipay

# ========== B 端资费 ==========
B_FREE_THRESHOLD=2000
B_FEE_RATE=0.0038
B_FEE_CAP=20

# ========== GLM 大模型 (AI 风控) ==========
GLM_API_KEY=
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4-flash

# ========== 公证服务商 ==========
# 公证云
NOTARY_GONGZHENG_API_KEY=
NOTARY_GONGZHENG_API_URL=
# 法大大
NOTARY_FADADA_API_KEY=
NOTARY_FADADA_API_URL=