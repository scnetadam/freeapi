# 龟钮印证 L0 结算壳 — 环境变量

# ========== 服务配置 ==========
PORT=3000
HTTP_PORT=80
NODE_ENV=development

# ========== 模拟模式 ==========
# IDE 模拟器中设为 true 跳过支付宝 App 支付，使用模拟确认弹窗
ALIPAY_SIMULATE=true

# ========== 支付宝沙箱 (L1 通道) ==========
# 未配置时自动使用模拟模式
ALIPAY_APP_ID=2021006168648698
ALIPAY_MERCHANT_PID=2088721102800728
ALIPAY_APP_PRIVATE_
ALIPAY_PUBLIC_
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# ========== 支付通道开关 ==========
# 逗号分隔: alipay,wechat,other
PAYMENT_CHANNELS=alipay,wechat

# ========== 微信支付 (JSAPI 小程序) ==========
WECHAT_APP_ID=wx85f61ef6c155f30d
WECHAT_MCH_ID=1618395446
# WECHAT_API_V3_KEY=32位密钥，填入后自动启用真实支付
WECHAT_SIMULATE=true
WECHAT_NOTIFY_URL=

# ========== B 端资费 ==========
B_FREE_THRESHOLD=2000
B_FEE_RATE=0.0038
B_FEE_CAP=50000

# ========== GLM 大模型 (AI 风控) ==========
GLM_API_KEY=5c65c6ea961c41428b4f7428d9ebfc49.PWmlgJ4sYIAFWtja
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_DEFAULT_MODEL=glm-4-flash

# ========== 跨项目 API 密钥 ==========
# 格式: API_KEY_xxx=项目名:密钥
# 其他项目通过此密钥调用龟钮印证 Agent 微交易 API
API_KEY_deveco=龟钮印信:deveco-agent-key-20260709

# ========== 公证服务商 ==========
# 公证云
NOTARY_GONGZHENG_API_KEY=
NOTARY_GONGZHENG_API_URL=
# 法大大
NOTARY_FADADA_API_KEY=
NOTARY_FADADA_API_URL=